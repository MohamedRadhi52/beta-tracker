# ─── Python & Environnement virtuel ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
venv/
env/
.env

# ─── YOLO, Wandb & Entraînement ───────────────────────────────────────────────
runs/
wandb/
*.cache

# Ignorer les poids YOLO téléchargés automatiquement à la racine (ex: yolov8s-seg.pt)
*.pt
!models/*.pt

# ─── Datasets ─────────────────────────────────────────────────────────────────
# Ignorer les datasets téléchargés depuis Roboflow
Climbing-Hold-Detection-*/
datasets/

# ─── Fichiers de sortie générés ───────────────────────────────────────────────
*.mp4
*.mov
*.avi
!assets/*.mp4

# ─── OS & IDE ─────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/